<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bot Control Panel</title>
    <link
      rel="icon" type="image/x-icon" href="/favicon.ico"
    />
    <link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
    <link rel="stylesheet" href="/style.css" />

    <!-- GÜVENLİK: CSRF Token -->
    <meta name="csrf-token" content="<%= csrfToken %>">

    <!-- DÜZELTME: Sunucu verilerini JavaScript'e aktaran script bloğu -->
    <script>
      const CLIENT_ID = "<%= clientId %>";
      const APP_URL = "<%= APP_URL %>"; // YENİ: APP_URL'i global değişkene ata
      const USER_ID = "<%= USER_ID %>";
      window.isBotOwner = '<%= isBotOwner %>' === 'true';
    </script>
  </head>
  <body>
    <div class="dashboard-container">
      <aside class="sidebar">
        <div id="current-server" class="sidebar-header">
          <img id="current-server-icon" src="" alt="" class="server-icon" />
          <span id="current-server-name">Sunucu seçin</span>
          <!-- YENİ: Mobil Menü Butonu -->
          <button id="mobile-menu-toggle" class="mobile-menu-toggle">
            <i class="fa-solid fa-bars"></i>
          </button>
        </div>
        <nav class="sidebar-nav">
          <a href="#" class="nav-link active" data-page="dashboard-page">
            <i class="fa-solid fa-house fa-fw"></i> Gösterge Paneli
          </a>
          <a href="#" class="nav-link" data-page="leaderboard-page">
            <i class="fa-solid fa-trophy fa-fw"></i> Sıralama
          </a>
          <a href="#" class="nav-link" data-page="stats-page">
            <i class="fa-solid fa-chart-simple fa-fw"></i> İstatistikler
          </a>
          <a href="#" class="nav-link" data-page="invites-page">
            <i class="fa-solid fa-envelope-open-text fa-fw"></i> Davetler
          </a>
          <a href="#" class="nav-link" data-page="roles-page">
            <i class="fa-solid fa-tags fa-fw"></i> Rol Yönetimi
          </a>
          <a href="#" class="nav-link" data-page="members-page">
            <i class="fa-solid fa-users fa-fw"></i> Üye Yönetimi
          </a>
          <a href="#" class="nav-link" data-page="audit-log-page">
            <i class="fa-solid fa-clipboard-list fa-fw"></i> Denetim Kaydı
          </a>
          <% if (isBotOwner === 'true') { %>
            <a href="#" class="nav-link" data-page="fivem-page">
              <i class="fa-solid fa-gamepad fa-fw"></i> FiveM Yönetimi
            </a>
          <% } %>
          <a href="#" class="nav-link" data-page="music-player-page">
            <i class="fa-solid fa-circle-play fa-fw"></i> Müzik Çalar
          </a>
          <a href="#" class="nav-link" data-page="mod-log-page">
            <i class="fa-solid fa-gavel fa-fw"></i> Moderasyon Logları
          </a>
          <a href="#" class="nav-link" data-page="bans-page">
            <i class="fa-solid fa-user-slash fa-fw"></i> Yasaklı Kullanıcılar
          </a>
          <a href="#" class="nav-link" data-page="warnings-page">
            <i class="fa-solid fa-bell fa-fw"></i> Uyarı Geçmişi
          </a>
          <a href="#" class="nav-link" data-page="custom-commands-page">
            <i class="fa-solid fa-terminal fa-fw"></i> Özel Komutlar
          </a>
          <a href="#" class="nav-link" data-page="embed-builder-page">
            <i class="fa-solid fa-paintbrush fa-fw"></i> Embed Oluşturucu
          </a>
          <a href="#" class="nav-link" data-page="scheduled-tasks-page">
            <i class="fa-solid fa-clock fa-fw"></i> Zamanlanmış Mesajlar
          </a>
          <a href="#" class="nav-link" data-page="backups-page">
            <i class="fa-solid fa-floppy-disk fa-fw"></i> Yedekleme
          </a>
          <a href="#" class="nav-link" data-page="plugins-page">
            <i class="fa-solid fa-puzzle-piece fa-fw"></i> Eklentiler
          </a>
          <!-- YENİ: Sadece bot sahibi görebilir -->
          <% if (isBotOwner === 'true') { %>
            <a href="#" class="nav-link" data-page="authorized-users-page">
              <i class="fa-solid fa-user-check fa-fw"></i> Giriş Yapanlar
            </a>
            <a href="#" class="nav-link" data-page="panel-logs-page">
              <i class="fa-solid fa-file-lines fa-fw"></i> Panel Logları
            </a>
            <a href="#" class="nav-link" data-page="trusted-users-page">
              <i class="fa-solid fa-user-shield fa-fw"></i> Güvenilir Kullanıcılar
            </a>
            <a href="#" class="nav-link" data-page="update-notes-page">
              <i class="fa-solid fa-newspaper fa-fw"></i> Güncelleme Notları
            </a>
          <% } %>
        </nav>
        <div class="sidebar-footer">
          <button id="add-server-btn" class="sidebar-btn" data-action="add-server">
            <i class="fa-solid fa-plus fa-fw"></i> Sunucuya Ekle
          </button>
          <button id="logout-btn" class="sidebar-btn logout" data-action="logout">
            <i class="fa-solid fa-right-from-bracket fa-fw"></i> Çıkış Yap
          </button>
        </div>
      </aside>

      <main class="main-content">
        <input
          type="file"
          id="import-settings-input"
          style="display: none"
          accept=".json"
        />
        <div id="unsaved-changes-bar" class="unsaved-changes-bar">
          <span
            >Kaydedilmemiş değişiklikleriniz var. Sayfadan ayrılmadan önce
            kaydettiğinizden emin olun.</span >
            <button id="save-all-changes-btn" data-action="save-all">Tümünü Kaydet</button>
        </div>

        <!-- Page 0: Dashboard -->
        <div class="page-content" id="dashboard-page">
          <header class="main-header">
            <h2>📊 Genel Bakış</h2>
          </header>
          <!-- YENİ: İzin Uyarısı Alanı -->
          <div id="permission-warning-container" class="beta-notice" style="display: none; background: rgba(239, 68, 68, 0.08); border-color: var(--red);">
            <i class="fa-solid fa-shield-halved" style="color: var(--red);"></i>
            <div id="permission-warning-text"></div>
          </div>
          <!-- Uyarı Alanı Sonu -->
          <div class="stats-grid" id="dashboard-stats-grid">
            <!-- Stat cards will be inserted here by JS -->
          </div>
          <div class="recent-activity-container">
            <h3>Son Aktiviteler</h3>
            <div id="recent-activity-list">
              <!-- Recent activity will be inserted here by JS -->
            </div>
          </div>
        </div>

        <!-- Page: Plugins (Birleştirilmiş) -->
        <div class="page-content" id="plugins-page" style="display: none">
          <header class="main-header">
            <h2><i class="fa-solid fa-puzzle-piece"></i> Eklentiler</h2>
            <div class="header-controls">
              <input type="text" id="plugin-search-input" class="setting-input" placeholder="Eklenti ara...">
              <button data-action="import-settings" class="header-action-btn"><i class="fa-solid fa-upload"></i> İçe Aktar</button>
              <button data-action="export-settings" class="header-action-btn"><i class="fa-solid fa-download"></i> Dışa Aktar</button>
              <button data-action="reset-all-settings" class="header-action-btn danger"><i class="fa-solid fa-trash-arrow-up"></i> Sıfırla</button>
            </div>
          </header>

          <div class="tabs-container">
            <button class="tab-link active" data-tab="moderation-tab">🛡️ Moderasyon & Güvenlik</button>
            <button class="tab-link" data-tab="management-tab">⚙️ Yönetim & Otomasyon</button>
            <button class="tab-link" data-tab="fun-tab">🎉 Etkileşim & Eğlence</button>
          </div>

          <div id="moderation-tab" class="tab-content active">
            <div class="plugins-grid">
              <div class="plugin-card" data-module="moderation">
                <div class="plugin-header">
                  <i class="fa-solid fa-shield-halved"></i>
                  <h3>Moderation</h3>
                  <i class="fa-solid fa-chevron-down collapse-icon"></i>
                  <label class="switch" style="margin-left: auto"
                    ><input
                      type="checkbox"
                      data-setting="enabled"
                      class="enable-toggle" /><span class="slider"></span
                  ></label>
                </div>
                <p class="plugin-description">
                  Otomatik günlük kaydı ve moderasyon araçlarıyla sunucunuzu
                  güvende tutun.
                </p>
                <div class="plugin-settings">
                  <label>Moderation Log Channel</label>
                  <p class="setting-description">
                    Tüm moderasyon işlemleri burada kaydedilecektir.
                  </p>
                  <select
                    data-setting="logChannelId"
                    class="setting-select"
                  ></select>
                  <hr class="separator" />
                  <label>Korunan Kanallar</label>
                  <p class="setting-description">
                    Bu kanallar, sunucu sahibi dışında kimse tarafından silinemez.
                  </p>
                  <div class="add-item-container">
                    <select id="channel-to-protect-select"></select>
                    <button
                      id="add-protected-channel-btn"
                      type="button"
                      class="add-btn"
                    >
                      Ekle
                    </button>
                  </div>
                  <div id="protected-channels-list" class="protected-list"></div>

                  <!-- YENİ: Otomatik Ceza Ayarları -->
                  <hr class="separator" />
                  <div class="setting-with-header">
                    <label>Otomatik Cezalar</label>
                    <button type="button" id="add-punishment-btn" class="add-btn-small">
                      <i class="fa-solid fa-plus"></i> Kural Ekle
                    </button>
                  </div>
                  <p class="setting-description">
                    Belirli uyarı sayısına ulaşan kullanıcılara otomatik olarak ceza verin.
                  </p>
                  <div id="auto-punishments-list" class="item-list-container">
                    <!-- Ceza kuralları buraya JS ile render edilecek -->
                  </div>
                  <div id="add-punishment-form" class="add-item-container" style="margin-top: 10px; display: none;">
                    <input type="number" id="new-punishment-count" class="setting-input" placeholder="Uyarı Sayısı" min="1" style="width: 120px;">
                    <select id="new-punishment-action" style="width: 120px;"><option value="timeout">Sustur</option><option value="kick">At</option><option value="ban">Yasakla</option></select>
                    <input type="number" id="new-punishment-duration" class="setting-input" placeholder="Süre (dk)" min="1" style="width: 100px;">
                    <button type="button" id="save-new-punishment-btn" class="add-btn">Kaydet</button>
                    <button type="button" id="cancel-new-punishment-btn" class="remove-item-btn" style="background-color: #747f8d;">İptal</button>
                  </div>
                  <!-- Otomatik Ceza Ayarları Sonu -->
                </div>
                <button class="save-button" data-action="save-plugin">
                  Ayarları Kaydet<span class="unsaved-indicator"></span>
                </button>
              </div>

              <div class="plugin-card" data-module="antiSpam">
                <div class="plugin-header">
                  <i class="fa-solid fa-link-slash"></i>
                  <h3>Link Engelleyici</h3>
                  <i class="fa-solid fa-chevron-down collapse-icon"></i>
                  <label class="switch" style="margin-left: auto">
                    <input
                      type="checkbox"
                      data-setting="enabled"
                      class="enable-toggle"
                    />
                    <span class="slider"></span>
                  </label>
                </div>
                <p class="plugin-description">
                  Sunucunuzda Discord davetlerini ve diğer harici linkleri
                  engelleyin.
                </p>
                <div class="plugin-settings">
                  <div class="setting-with-toggle">
                    <label>Discord Davetlerini Engelle</label>
                    <label class="switch">
                      <input type="checkbox" data-setting="blockInvites" />
                      <span class="slider"></span>
                    </label>
                  </div>
                  <div class="setting-with-toggle">
                    <label>Diğer Linkleri Engelle</label>
                    <label class="switch">
                      <input type="checkbox" data-setting="blockLinks" />
                      <span class="slider"></span>
                    </label>
                  </div>
                  <hr class="separator" />
                  <label>İzinli Roller</label>
                  <p class="setting-description">
                    Bu rollerdeki üyeler link paylaşabilir.
                  </p>
                  <div
                    id="antispam-allowed-roles-list"
                    class="protected-list"
                  ></div>
                  <div class="add-item-container" style="margin-top: 10px">
                    <select
                      id="antispam-role-select"
                      class="setting-select"
                    ></select>
                    <button
                      id="add-antispam-role-btn"
                      type="button"
                      class="add-btn"
                    >
                      Ekle
                    </button>
                  </div>
                  <hr class="separator" />
                  <label>Log Kanalı</label>
                  <p class="setting-description">
                    Engellenen linkler bu kanala bildirilir.
                  </p>
                  <select
                    data-setting="logChannelId"
                    class="setting-select"
                  ></select>
                </div>
                <button class="save-button" data-action="save-plugin">
                  Ayarları Kaydet<span class="unsaved-indicator"></span>
                </button>
              </div>
  
              <div class="plugin-card" data-module="antiRaid">
                <div class="plugin-header">
                  <i class="fa-solid fa-user-shield"></i>
                  <h3>Anti-Spam / Raid</h3>
                  <i class="fa-solid fa-chevron-down collapse-icon"></i>
                  <label class="switch" style="margin-left: auto">
                    <input
                      type="checkbox"
                      data-setting="enabled"
                      class="enable-toggle"
                    />
                    <span class="slider"></span>
                  </label>
                </div>
                <p class="plugin-description">
                  Çok hızlı mesaj gönderen kullanıcıları otomatik olarak
                  cezalandırın.
                </p>
                <div class="plugin-settings">
                  <label>Eşik Değerleri</label>
                  <p class="setting-description">
                    Bir kullanıcı
                    <input
                      type="number"
                      data-setting="messageLimit"
                      class="inline-input"
                      min="2"
                      max="50"
                      value="5"
                    />
                    mesajı
                    <input
                      type="number"
                      data-setting="timeInterval"
                      data-type="seconds"
                      class="inline-input"
                      min="1"
                      max="60"
                      value="3"
                    />
                    saniye içinde gönderirse cezalandır.
                  </p>
                  <hr class="separator" />
                  <label>Eylem</label>
                  <p class="setting-description">
                    Kullanıcıya hangi eylem uygulansın?
                  </p>
                  <select data-setting="action" class="setting-select">
                    <option value="timeout">Sustur (10 dk)</option>
                    <option value="kick">Sunucudan At</option>
                    <option value="ban">Yasakla</option>
                  </select>
                </div>
                <button class="save-button" data-action="save-plugin">
                  Ayarları Kaydet<span class="unsaved-indicator"></span>
                </button>
              </div>

              <!-- YENİ: Sunucu Koruması (Guard) Kartı -->
              <div class="plugin-card" data-module="guard">
                <div class="plugin-header">
                  <i class="fa-solid fa-dragon"></i>
                  <h3>Sunucu Koruması (Guard)</h3>
                  <i class="fa-solid fa-chevron-down collapse-icon"></i>
                  <label class="switch" style="margin-left: auto">
                    <input
                      type="checkbox"
                      data-setting="enabled"
                      class="enable-toggle"
                    />
                    <span class="slider"></span>
                  </label>
                </div>
                <p class="plugin-description">
                  Sunucunuzu yetkili suistimallerine ve saldırılara karşı korur.
                  Kritik işlemleri yapanları otomatik olarak cezalandırır.
                </p>
                <div class="plugin-settings">
                  <div class="setting-with-toggle">
                    <label>Kanal/Rol Silindiğinde Yetki Düşür</label>
                    <label class="switch">
                      <input type="checkbox" data-setting="demoteOnDelete" />
                      <span class="slider"></span>
                    </label>
                  </div>
                   <p class="setting-description">
                    Birisi kanal veya rol sildiğinde, tüm yönetici yetkileri alınır.
                  </p>
                  <hr class="separator" />
                  <label>Güvenli Roller</label>
                  <p class="setting-description">
                    Bu rollerdeki üyeler koruma sisteminden etkilenmez (Örn: Kurucu).
                  </p>
                  <div
                    id="guard-safe-roles-list"
                    class="protected-list"
                  ></div>
                  <div class="add-item-container" style="margin-top: 10px">
                    <select id="guard-safe-role-select" class="setting-select" data-setting="safeRolesSelect"></select>
                    <button id="add-guard-safe-role-btn" type="button" class="add-btn">Ekle</button>
                  </div>
                  <hr class="separator" />
                  <label>Log Kanalı</label>
                  <p class="setting-description">
                    Tüm koruma eylemleri bu kanala bildirilir.
                  </p>
                  <select data-setting="logChannelId" class="setting-select"></select>
                </div>
                <button class="save-button" data-action="save-plugin">
                  Ayarları Kaydet<span class="unsaved-indicator"></span>
                </button>
              </div>

              <!-- YENİ: Jail (Hapishane) Sistemi Kartı -->
              <div class="plugin-card" data-module="jail">
                <div class="plugin-header">
                  <i class="fa-solid fa-person-shelter"></i>
                  <h3>Jail (Hapishane) Sistemi</h3>
                  <i class="fa-solid fa-chevron-down collapse-icon"></i>
                  <label class="switch" style="margin-left: auto">
                    <input
                      type="checkbox"
                      data-setting="enabled"
                      class="enable-toggle"
                    />
                    <span class="slider"></span>
                  </label>
                </div>
                <p class="plugin-description">
                  Sorunlu kullanıcıları sunucudan atmadan izole edin.
                  `/jail` ve `/unjail` komutlarını kullanır.
                </p>
                <div class="plugin-settings">
                  <label>Jail Rolü</label>
                  <p class="setting-description">
                    Hapise atılan kullanıcılara verilecek rol. Yoksa, komut kullanıldığında otomatik oluşturulur.
                  </p>
                  <select data-setting="jailRoleId" class="setting-select"></select>
                  <hr class="separator" />
                  <label>Jail Log Kanalı</label>
                  <p class="setting-description">
                    Tüm hapishane işlemleri bu kanala bildirilir.
                  </p>
                  <select data-setting="logChannelId" class="setting-select"></select>
                </div>
                <button class="save-button" data-action="save-plugin">
                  Ayarları Kaydet<span class="unsaved-indicator"></span>
                </button>
              </div>

              <!-- YENİ: Otomatik Moderasyon Kartı -->
              <div class="plugin-card" data-module="autoModeration">
                <div class="plugin-header">
                  <i class="fa-solid fa-robot"></i>
                  <h3>Otomatik Moderasyon</h3>
                  <i class="fa-solid fa-chevron-down collapse-icon"></i>
                  <label class="switch" style="margin-left: auto">
                    <input type="checkbox" data-setting="enabled" class="enable-toggle" />
                    <span class="slider"></span>
                  </label>
                </div>
                <p class="plugin-description">
                  Yasaklı kelimeleri, etiket spamını ve büyük harf kullanımını otomatik olarak denetleyin.
                </p>
                <div class="plugin-settings">
                  <!-- Yasaklı Kelimeler Alt Bölümü -->
                  <div class="sub-plugin">
                    <div class="sub-plugin-header">
                      <h4>Yasaklı Kelime Filtresi</h4>
                    </div>
                    <div class="plugin-settings" style="display: flex;">
                      <label>Yasaklı Kelimeler</label>
                      <p class="setting-description">
                        Bu kelimeleri içeren mesajlar otomatik olarak işleme alınır.
                      </p>
                      <div class="add-item-container">
                        <input type="text" id="new-banned-word" class="setting-input" placeholder="Yeni kelime ekle...">
                        <button id="add-banned-word-btn" type="button" class="add-btn">Ekle</button>
                      </div>
                      <div id="banned-words-list" class="item-list-container"></div>
                      <label style="margin-top: 15px;">Uygulanacak Eylem</label>
                      <select data-setting="bannedWordsAction" class="setting-select">
                        <option value="delete_warn">Sil ve Uyar</option>
                        <option value="delete">Sadece Sil</option>
                      </select>
                    </div>
                  </div>

                  <!-- Etiket Spam Alt Bölümü -->
                  <div class="sub-plugin">
                    <div class="sub-plugin-header">
                      <h4>Etiket (Mention) Spam Koruması</h4>
                      <label class="switch">
                        <input type="checkbox" data-setting="mentionSpamEnabled" />
                        <span class="slider"></span>
                      </label>
                    </div>
                    <div class="plugin-settings">
                      <label>Etiket Limiti</label>
                      <p class="setting-description">
                        Bir mesajda bu sayıya eşit veya daha fazla etiket varsa spam sayılır.
                      </p>
                      <input type="number" data-setting="mentionSpamLimit" class="setting-input" min="2" value="7">
                      <label style="margin-top: 15px;">Uygulanacak Eylem</label>
                      <select data-setting="mentionSpamAction" class="setting-select">
                        <option value="warn">Uyar</option>
                        <option value="timeout">Sustur (10 dk)</option>
                        <option value="kick">At</option>
                      </select>
                    </div>
                  </div>

                  <!-- Büyük Harf Spam Alt Bölümü -->
                  <div class="sub-plugin">
                    <div class="sub-plugin-header">
                      <h4>Büyük Harf (Caps Lock) Koruması</h4>
                      <label class="switch">
                        <input type="checkbox" data-setting="capsLockSpamEnabled" />
                        <span class="slider"></span>
                      </label>
                    </div>
                    <div class="plugin-settings">
                      <label>Büyük Harf Oranı (%)</label>
                      <p class="setting-description">
                        Bir mesajdaki harflerin yüzde kaçı büyükse spam sayılır.
                      </p>
                      <input type="number" data-setting="capsLockSpamPercentage" class="setting-input" min="10" max="100" value="70">
                      <label style="margin-top: 15px;">Uygulanacak Eylem</label>
                      <select data-setting="capsLockSpamAction" class="setting-select">
                        <option value="warn">Uyar</option>
                        <option value="delete">Mesajı Sil</option>
                      </select>
                    </div>
                  </div>

                  <hr class="separator" />
                  <label>Görmezden Gelinecek Roller</label>
                  <p class="setting-description">
                    Bu rollerdeki üyeler otomatik moderasyondan etkilenmez.
                  </p>
                  <div id="automod-ignored-roles-list" class="protected-list"></div>
                  <div class="add-item-container" style="margin-top: 10px">
                    <select id="automod-ignored-role-select" class="setting-select"></select>
                    <button id="add-automod-ignored-role-btn" type="button" class="add-btn">Ekle</button>
                  </div>

                  <hr class="separator" />
                  <label>Log Kanalı</label>
                  <p class="setting-description">
                    Tüm otomatik moderasyon eylemleri bu kanala bildirilir.
                  </p>
                  <select data-setting="logChannelId" class="setting-select"></select>
                </div>
                <button class="save-button" data-action="save-plugin">Ayarları Kaydet<span class="unsaved-indicator"></span></button>
              </div>

              <!-- YENİ: Yasaklı Kullanıcılar Kartı (Sadece Bot Sahibi) -->
              <% if (isBotOwner === 'true') { %>
                <div class="plugin-card" data-module="blockedUsers">
                  <div class="plugin-header">
                    <i class="fa-solid fa-user-lock"></i>
