            <label for="ticket-topic-emoji">Emoji (İsteğe Bağlı)</label>
            <input type="text" id="ticket-topic-emoji" placeholder="Örn: 🛠️" />
          </div>
          <div class="form-group">
            <label for="ticket-topic-category"
              >Özel Kategori (İsteğe Bağlı)</label
            >
            <p class="setting-description">
              Seçilmezse, ana bilet ayarlarındaki kategori kullanılır.
            </p>
            <select id="ticket-topic-category" class="setting-select" data-channel-types="category"></select>
          </div>
          <div class="form-group">
            <label for="ticket-topic-support-role"
              >Özel Destek Rolü (İsteğe Bağlı)</label
            >
            <p class="setting-description">
              Seçilmezse, ana bilet ayarlarındaki destek rolü kullanılır.
            </p>
            <select
              id="ticket-topic-support-role"
              class="setting-select"
            ></select>
          </div>
          <div class="modal-actions">
            <button
              type="button"
              id="ticket-topic-modal-cancel"
              class="sidebar-btn"
            >
              İptal
            </button>
            <button
              type="submit"
              id="ticket-topic-modal-save"
              class="sidebar-btn save"
            >
              Kaydet
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- YENİ: Kullanıcı Profili Modal'ı -->
    <div id="user-profile-modal" class="modal-overlay" style="display: none;">
      <div class="modal-content confirm-modal-content" style="max-width: 400px; text-align: left;">
        <div id="user-profile-content">
          <!-- Profil içeriği buraya JS ile yüklenecek -->
          <div style="text-align: center; padding: 20px;">
            <i class="fa-solid fa-spinner fa-spin" style="font-size: 2em;"></i>
            <p>Kullanıcı bilgileri yükleniyor...</p>
          </div>
        </div>
        <div class="modal-actions" style="justify-content: center; border-top: none; padding-top: 0;">
          <button id="user-profile-modal-close" class="sidebar-btn">Kapat</button>
        </div>
      </div>
    </div>

    <!-- YENİ: Zamanlanmış Mesaj Önizleme Modalı -->
    <div id="task-preview-modal" class="modal-overlay" style="display: none">
      <div class="modal-content" style="max-width: 800px; text-align: left;">
        <h3>Mesaj Önizlemesi</h3>
        <div class="preview-pane" style="background: #313338; padding: 16px; border-radius: 8px; margin-top: 15px;">
            <div id="task-preview-content"></div>
        </div>
        <div class="modal-actions">
          <button id="task-preview-close" class="sidebar-btn">Kapat</button>
        </div>
      </div>
    </div>

    <!-- YENİ: Şarkı Sözleri Modalı -->
    <div id="lyrics-modal" class="modal-overlay" style="display: none;">
      <div class="modal-content" style="max-width: 600px; text-align: left; max-height: 80vh; display: flex; flex-direction: column;">
        <h3 id="lyrics-title" style="margin-top: 0; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">Şarkı Sözleri</h3>
        <div id="lyrics-content" style="white-space: pre-wrap; overflow-y: auto; flex-grow: 1; padding-right: 10px; line-height: 1.6; font-size: 0.95em; color: var(--text-primary);"></div>
        <div class="modal-actions" style="margin-top: 15px; padding-top: 10px; display: flex; justify-content: flex-end; gap: 10px;">
          <button id="lyrics-copy-btn" class="sidebar-btn" style="background-color: var(--blue); color: white; width: auto;"><i class="fa-solid fa-copy"></i> Kopyala</button>
          <button id="lyrics-modal-close" class="sidebar-btn">Kapat</button>
        </div>
      </div>
    </div>

    <style>
      #user-profile-banner { width: 100%; height: 120px; background-size: cover; background-position: center; border-radius: 16px 16px 0 0; margin: -35px -35px 20px -35px; }
      #user-profile-avatar { width: 90px; height: 90px; border-radius: 50%; border: 4px solid var(--bg-tertiary); margin-top: -65px; margin-bottom: 10px; }
      #user-profile-tag { font-size: 1.5em; font-weight: 700; color: white; }
      #user-profile-id { font-size: 0.9em; color: var(--text-secondary); font-family: 'Courier New', Courier, monospace; margin-bottom: 15px; }
      #user-profile-created { font-size: 0.9em; color: var(--text-secondary); }
    </style>

    <!-- Socket.io İstemcisi (Otomatik Güncellemeler İçin) -->
    <script src="/socket.io/socket.io.js"></script>

    <!-- Eski dashboard.js yerine yeni modüler yapıyı kullanıyoruz -->
    <script type="module" src="/js/app.js"></script>
  </body>
</html>
